pipeline {
    agent any
    environment {
        Defaultworkspace = 'project1/java-docker-jenkins-app'
        //SONARQUBE_URL = 'http://your-sonarqube-server:9000'
        AWS_ACCOUNT_ID = credentials('aws-account-id')
        AWS_REGION = credentials('aws-region')
        ECR_REPOSITORY_NAME = credentials('ecr-repository-name')
        DOCKER_IMAGE_NAME = 'java-docker-app'
        IMAGE_TAG = "${BUILD_NUMBER}"
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ///SONARQUBE_URL = 'http://localhost:9000'
        ///SONARQUBE_TOKEN = credentials('sonarqube-token')
    }
    tools { 
        maven 'maven' 
        
    }
    stages {
        stage('Code Checkout') {
            steps {
               checkout scm
               sh 'echo "Code checked out successfully!"'
               sh'cd ${Defaultworkspace} && ls -la' 
            }
        }
        stage('Maven Build') {
            steps {
                   dir('project1/java-docker-jenkins-app') {
                    sh 'mvn --version'
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        // stage('SonarQube Testing') {
        //     steps {
        //  /       sh 'mvn sonar:sonar'
        //     }
        // }
        stage('Docker Build') {
            steps {
                dir('project1/java-docker-jenkins-app') {
                    sh '''
                        docker build -t ${DOCKER_IMAGE_NAME}:${IMAGE_TAG} .
                        docker tag ${DOCKER_IMAGE_NAME}:${IMAGE_TAG} ${DOCKER_IMAGE_NAME}:latest

                        PREVIOUS_TAG=$((${IMAGE_TAG}-1))

                        if [ "$PREVIOUS_TAG" -gt 0 ]; then
                            docker rmi ${DOCKER_IMAGE_NAME}:${PREVIOUS_TAG} 2>/dev/null || true
                        fi
                    '''
                }
            }
        }
        stage('Login to ECR and Push') {
            steps {
                withCredentials([[
                $class: 'AmazonWebServicesCredentialsBinding',
                credentialsId: 'aws'
                ]]) {
                sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ECR_REGISTRY}
                    
                    docker tag ${DOCKER_IMAGE_NAME}:${IMAGE_TAG} ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:${IMAGE_TAG}
                    docker tag ${DOCKER_IMAGE_NAME}:latest ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:latest
                    
                    docker push ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:${IMAGE_TAG}
                    docker push ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:latest
                '''
                }
            }
        }


        stage('Deploy Container') {
            steps {
                sh '''
                    docker stop java-docker-app-container 2>/dev/null || true
                    docker rm java-docker-app-container 2>/dev/null || true
                    
                    docker run -d \
                        --name java-docker-app-container \
                        -p 9090:9090 \
                        ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:${IMAGE_TAG}
                    
                    sleep 5
                    docker logs java-docker-app-container
                '''
            }
        }
    }
}
